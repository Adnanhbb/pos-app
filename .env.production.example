# Production environment template for jawad-bro.
# Copy these values to your hosting provider's environment/config system.
# If PHP environment variables are unavailable, create api/config/private.php
# on the server from api/config/private.example.php instead.
# Do not commit real production secrets or api/config/private.php.

# Public frontend build settings.
# Use the production HTTPS API URL. Example:
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=https://api.example.com

# Public frontend asset base path used by Vite during production builds.
# Use / for domain-root hosting, or a subfolder path such as /jawad-bro-rehearsal/.
VITE_BASE_PATH=/

# Backend CRUD auth enforcement.
# Keep disabled during initial production validation unless staged enforcement has passed.
# Accepted app values are expected to be interpreted by backend config as on/off truthy values.
APP_ENV=production
CRUD_AUTH_ENFORCEMENT=off

# Replay worker token placeholder.
# Generate a strong random value in production and store it only in secure server config.
REPLAY_WORKER_TOKEN=replace-with-strong-random-token

# Backend MySQL connection placeholders.
# Prefer hosting-provider environment variables. The protected, gitignored
# api/config/private.php file is the shared-hosting fallback.
DB_HOST=localhost
DB_NAME=replace_with_database_name
DB_USER=replace_with_database_user
DB_PASS=replace_with_database_password

# CORS/frontend origin placeholder if your deployment uses env-driven CORS config.
# Example: https://app.example.com
FRONTEND_ORIGIN=https://app.example.com

# Local CORS origins are disabled by default. Keep false in production.
# Same-origin frontend + /api hosting does not need a cross-origin allowlist.
CORS_ALLOW_LOCAL=false

# Production notes:
# - HTTPS is required for login/session/token use.
# - Auto-sync must remain disabled initially.
# - Manual replay should remain gated and operator-controlled.
# - Never place real DB passwords, replay tokens, bearer tokens, or session secrets in source control.
# - Validate backups before and after rollout.
# Development-only legacy shortcut. Keep false for client, rehearsal, package, and production builds.
VITE_ENABLE_DEV_BACKDOOR=false

# Device-local offline login fallback. Default false prevents accidental bypass.
# Set true only after explicitly approving offline access for the client device.
# When enabled, fallback is allowed only when the API cannot be reached; an online
# backend credential rejection never falls back to IndexedDB credentials.
VITE_ALLOW_OFFLINE_LOGIN=false
